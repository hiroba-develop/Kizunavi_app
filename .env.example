# ===========================================
# 環境変数（ルート: Docker Compose およびローカル起動の参照元）
# ===========================================
# このファイルを .env にコピーして編集してください
#   cp .env.example .env
#
# プロファイルは dev / prod の 2 種類のみです。
# - dev: 自PC（bootRun / Docker）と AWS dev EC2 で共通。接続先は dev の AWS RDS / SES。
# - prod: AWS prod EC2 のみ。接続先は prod の AWS RDS / SES。
# ローカル・Docker でも dev 用の RDS / SES に接続します（H2 は使用しません）。
#
# テンプレート複製時のポート採番（Google スプレッドシートが正）:
# https://docs.google.com/spreadsheets/d/1pMseDeBjZCV_ppZLVuaaD78iooxR7yeXWP5jsxzJcS8/edit?gid=0#gid=0
# ルール・手順: docs/port-registry.md

# -------------------------------------------
# ローカル・Docker ホストポート（コンテナ内は frontend:5175 / backend:8082）
# -------------------------------------------
FRONTEND_PORT=5175
BACKEND_PORT=8082

# バックエンドが許可するブラウザオリジン（カンマ区切り）。FRONTEND_PORT と一致させる
CORS_ALLOWED_ORIGINS=http://localhost:5175

# メール内のフロントURL（パスワードリセット等）
APP_FRONTEND_BASE_URL=http://localhost:5175

# frontend の Vite proxy 先（Docker Compose 時の `/api` 中継先）
VITE_PROXY_TARGET=http://backend:8082

# -------------------------------------------
# Spring プロファイル（dev または prod）
# -------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -------------------------------------------
# Secrets Manager（DB / JWT の正）
# -------------------------------------------
# シークレット名:
# - kizunavi/dev/database, kizunavi/prod/database
# - kizunavi/dev/jwt, kizunavi/prod/jwt
AWS_SECRETS_ENABLED=true
AWS_SECRETS_REGION=ap-northeast-1
AWS_SECRETS_PREFIX=kizunavi

# HikariCP 接続プール設定
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5

# -------------------------------------------
# AWS SES（dev / prod とも有効）
# -------------------------------------------
# ローカルで AWS CLI プロファイルを使う場合はキーを空のままにする
AWS_SES_REGION=ap-northeast-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_SES_FROM_EMAIL=info@kizunavi.jp

# -------------------------------------------
# ログ・JPA（任意。起動場所による差分はここで調整）
# -------------------------------------------
# 自PCで詳細に追いたいときの例:
# LOG_LEVEL=DEBUG
# JPA_SHOW_SQL=true
# HIBERNATE_SQL_LOG=DEBUG
# HIBERNATE_BIND_LOG=TRACE
# JPA_DDL_AUTO は dev で既定 update、prod で既定 validate（application-*.yml 参照）
