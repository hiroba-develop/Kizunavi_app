# ===========================================
# 環境変数（ルート: Docker Compose およびローカル起動の参照元）
# ===========================================
# このファイルを .env にコピーして編集してください
#   cp .env.example .env
#
# プロファイルは dev / prod の 2 種類のみです。
# - dev: 自PC（bootRun / Docker）と AWS dev EC2 で共通。接続先は dev の AWS RDS / SES。
# - prod: AWS prod EC2 のみ。接続先は prod の AWS RDS / SES。
# ローカル・Docker でも dev 用の RDS / SES に接続します（H2 は使用しません）。
#
# テンプレート複製時のポート採番（Google スプレッドシートが正）:
# https://docs.google.com/spreadsheets/d/1pMseDeBjZCV_ppZLVuaaD78iooxR7yeXWP5jsxzJcS8/edit?gid=0#gid=0
# ルール・手順: docs/port-registry.md

# -------------------------------------------
# ローカル・Docker ホストポート（コンテナ内は frontend:5173 / backend:8080）
# -------------------------------------------
FRONTEND_PORT=5173
BACKEND_PORT=8080

# バックエンドが許可するブラウザオリジン（カンマ区切り）。FRONTEND_PORT と一致させる
CORS_ALLOWED_ORIGINS=http://localhost:5173

# メール内のフロントURL（パスワードリセット等）
APP_FRONTEND_BASE_URL=http://localhost:5173

# frontend の Vite proxy 先（Docker Compose 時の `/api` 中継先）
VITE_PROXY_TARGET=http://backend:8080

# -------------------------------------------
# Spring プロファイル（dev または prod）
# -------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -------------------------------------------
# JWT設定
# -------------------------------------------
# 本番（prod）では必ず強力なランダム値に変更してください（32文字以上）
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long

# -------------------------------------------
# データベース（dev / prod とも AWS RDS Oracle。必須）
# -------------------------------------------
DB_URL=jdbc:oracle:thin:@//your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:1521/ORCL
DB_USERNAME=template_user
DB_PASSWORD=template_pass

# HikariCP 接続プール設定
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5

# -------------------------------------------
# AWS SES（dev / prod とも有効。認証情報は必須）
# -------------------------------------------
AWS_SES_REGION=ap-northeast-1
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# -------------------------------------------
# ログ・JPA（任意。起動場所による差分はここで調整）
# -------------------------------------------
# 自PCで詳細に追いたいときの例:
# LOG_LEVEL=DEBUG
# JPA_SHOW_SQL=true
# HIBERNATE_SQL_LOG=DEBUG
# HIBERNATE_BIND_LOG=TRACE
# JPA_DDL_AUTO は dev で既定 update、prod で既定 validate（application-*.yml 参照）
