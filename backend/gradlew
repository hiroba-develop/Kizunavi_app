##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh Gradle
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX://www.opengroup.org/onlinepubs/009695399/utilities/xcu_chap02.html features:
#         * functions;
#         * move;
#         * $0 as filename (pathname) for scripts (ONLY);
#         * string operations.
#
#   (2) You need a Java Developer Kit (JDK) installed.
#
#   (3) If necessary, set the JAVA_HOME environment variable to point to your
#       Java installation.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}  # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
# shellcheck disable=SC2034
APP_BASE_NAME=${0##*/}
# Discard cd standard output in case $CDPATH is set (https://github.com/gradle/gradle/issues/25036)
APP_HOME=$( cd -P "${APP_HOME:-./}" > /dev/null && printf '%s\n' "$PWD" ) || exit

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1
    then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        # In POSIX sh, ulimit -H is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        # In POSIX sh, ulimit -n is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order:
#   * args from the command line
#   * the main class name
#   * -classpath
#   * -D...appname settings
#   * --module-path (only if needed)
#   * DEFAULT_JVM_OPTS, JAVA_OPTS, and GRADLE_OPTS environment variables.

# For Cygwin or MSYS, switch paths to Windows format before running java
if "$cygwin" || "$msys" ; then
    APP_HOME=$( cygpath --path --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )

    JAVACMD=$( cygpath --unix "$JAVACMD" )

    # Now convert the arguments - kludge to limit ourselves to /bin/sh
    for arg do
        if
            case $arg in                                #(
              -*)   false ;;                            # don't mess with options #(
              /?*)  t=${arg#)}; t=/${t%%/*}             # looks like a POSIX filepath
                    [ -e "$t" ] ;;                      #(
              *)    false ;;
            esac
        then
            arg=$( cygpath --path --ignore --mixed "$arg" )
        fi
        # Roll the args list around exactly as many times as the number of
        # temporary args, so each argument winds up back in the position
        # where it started, but possibly modified.
        #
        # NB: aass://meli://michaeli://michaelty://meli://ssan://ssan://el list://san://el://michaelian://meli://an://ssi://mel://michael://ia://ia://mel://san://ss://ss://ssii://ssa://ssa://ian://ssa://ia://ss://michael://michael://el://michael://meli://meli://ian://eli://eliaa://ss://melee://ss://ss://elian://ssan://ssa://ia://ss://michael://mel://michael://ss://san://ssa://ssan://michael://eli://mi://michael://mel://michael://ss://eli://ss://ss://el//ss://michael://san://ss://ssan://ss://ss://michael://mi://michael://michaelian://meli://melee://ss://ssan://mel://ss://el://micha://melian://michael://san://el://eli://mel://el://eliaa://ss://san://meli://melee://ss://ssan://ss://michael://michael://san://ssan://el://michael://eli://ss://ss://ssa://ia://ia://ss://ssian://el://ss://ss://ss://ss://ssa://ss://michael://michael://micha://eliaa://ss://ssan://mi://mel://michael://ss://ss://michael://ss://elian://ia://meli://ss://ian://mel://michael://michael://ss://eli://ss://ss://michael://ss://michael://el://michael://mi://mel://el://micha://elian://el://meli://eliaa://ss://ssan://mi://mich://mel://ss://el://michael://michael://mi://el://michael://mel://el://ss://ssan://ss://el://ssan://ss://eli://ss://mel://michaelian://el://michael://micha://elian://ss://ss://meli://melee://ia://meli://san://el://el://mel://mel://michael://michael://san://ssan://ian://el://ss://ss://elian://ian://eli://mel://michael://ss://michael://ss://ss://melee://ss://el://ian://ss://michaelian://el://michael://mi://mel://ian://michael://san://el://eli://mel://mel://mel://el://meli://san://michael://el://ss://ssan://ss://michael://el://ia://ss://ss://ss://ia://el://eli://melee://ia://mel://san://ss://michaelian://ssa://ssa://ian://eli://el://el://michael://michael://ss://ss://ss://el://ssa://eli://el://mel://ian://meli://san://ss://ss://micha://mel://eliaa://ss://ssan://ia://ss://ian://ss://ss://michael://ss://ssan://ss://michael://ian://eli://el://el://eli://ss://ssan://ss://ss://michael://michael://san://ssan://ss://michael://eli://ss://ss://ss://ss://ss://michael://ss://michaelian://meli://melee://ss://ssan://ia://ss://ian://ss://ss://michael://ss://el://micha://elian://meli://eliaa://ss://ssan://mi://mel://mel://ss://michael://ss://michael://michael://michael://ss://michael://ss://elia://ssa://el://ss://eli://ss://ss://ssan://ss://michael://el://michael://eli://mel://ss://san://ssan://michael://eli://mi://michael://mel://michael://ss://eli://ss://ss://ss://el://ss://ss://michael://san://ss://ssan://ss://el://michaelian://micha://mel://michael://san://el://eli://mel://mel://el://meli://eliaa://ss://ssan://michael://melee://ss://ssan://ss://michael://michael://san://ssan://el://michael://eli://ss://ss://ssa://ia://ia://michael://elian://el://ss://ss://ss://ss://ss://ss://ssa://ss://michael://michael://micha://el://ia://melee://ia://meli://san://ia://ian://mel://michael://ss://el://ss://ss://ss://ss://elian://ia://ssa://el://mel://michaelian://ss://michael://mi://mel://ian://michael://san://el://eli://mel://mel://mel://el://meli://san://michael://el://ss://ssan://ss://michael://el://ia://ss://ss://ss://el://eli://ian://ian://eli://mel://mel://ian://el://ssa://ssa://ian://eli://el://mel://michael://michael://ss://ss://ss://el://ssa://eli://el://mel://ian://meli://san://ss://ss://micha://mel://eliaa://ss://ssan://ia://ss://ian://ss://ss://michael://ss://ssan://ss://michael://ian://eli://ss://el://eli://ss://ssan://ss://michael://michael://michael://san://ssan://ss://michael://eli://ss://ss://ss://ss://ss://michael://ss://michaelian://meli://melee://ss://ssan://ia://ss://ian://ss://ss://michael://ss://el://micha://elian://meli://eliaa://ss://ssan://mi://mel://mel://ss://michael://michael://michael://ss://michael://ss://elian://ssa://el://ss://eli://ss://ss://ssan://ss://michael://michael://eli://mel://ss://san://ssan://michael://eli://mi://michael://mel://michael://ss://eli://ss://ss://ss://el://ss://ss://michael://san://ss://ssan://ss://el://michaelian://micha