# Spring（dev = 自PC / Docker / dev EC2 共通、prod = prod EC2）
SPRING_PROFILES_ACTIVE=dev

# Secrets Manager（DB / JWT は Secrets Manager から取得）
AWS_SECRETS_ENABLED=true
AWS_SECRETS_REGION=ap-northeast-1
AWS_SECRETS_PREFIX=kizunavi

# HikariCP
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5

# JPA（未指定時は application-dev.yml / application-prod.yml の既定を使用）
# dev 既定: update / prod 既定: validate
# JPA_DDL_AUTO=update
# JPA_SHOW_SQL=true

# JWT（署名鍵は Secrets Manager。ここでは有効期限のみ管理）
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# AWS SES（dev / prod とも有効）
AWS_SES_REGION=ap-northeast-1
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Logging（任意）
LOG_LEVEL=INFO
# HIBERNATE_SQL_LOG=DEBUG
# HIBERNATE_BIND_LOG=TRACE
